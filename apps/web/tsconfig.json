{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@hq/core/*": ["../../packages/core/*"],
      "@hq/react/*": ["../../packages/react/*"],
      "@hq/wasm-crypto": ["../../packages/wasm-crypto/pkg/wasm_crypto"],
      "@/*": ["src/*"],
      "@/domains/*": ["src/domains/*"],
      "@/shared/*": ["src/shared/*"]
    },
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    ".next/types/**/*.ts",
    "../../packages/core/**/*.ts",
    "../../packages/react/**/*.ts",
    "../../packages/react/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "farm",
    "../../packages/core/**/__tests__",
    "../../packages/react/**/__tests__"
  ]
}
