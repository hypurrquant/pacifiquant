{
  "$schema": "https://unpkg.com/unimported/schema.json",
  "entry": [
    "src/app/layout.tsx",
    "src/app/page.tsx",
    "src/app/**/page.tsx",
    "src/app/**/layout.tsx",
    "src/app/**/loading.tsx",
    "src/app/**/error.tsx",
    "src/app/**/not-found.tsx",
    "src/app/**/template.tsx",
    "src/app/**/default.tsx",
    "src/app/api/**/route.ts",
    "src/middleware.ts"
  ],
  "extensions": [".ts", ".tsx"],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/e2e/**",
    "**/farm/**",
    "**/scripts/**",
    "**/*.d.ts",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/stories/**",
    "**/*.stories.tsx"
  ],
  "ignoreUnimported": [
    "src/types/**",
    "src/shared/abi/**",
    "src/app/**/loading.tsx",
    "src/app/**/error.tsx",
    "src/app/**/not-found.tsx",
    "src/app/**/template.tsx",
    "src/app/**/default.tsx",
    "src/app/**/opengraph-image.tsx",
    "src/app/**/twitter-image.tsx",
    "src/app/**/icon.tsx",
    "src/app/**/apple-icon.tsx",
    "src/app/**/sitemap.ts",
    "src/app/**/robots.ts",
    "src/middleware.ts"
  ],
  "ignoreUnused": [],
  "ignoreUnresolved": [
    "@/*"
  ]
}
